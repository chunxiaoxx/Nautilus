# ============================================================================
# Nautilus Phase 3 Backend - 测试环境配置
# ============================================================================
#
# 重要提示：
# 1. 此文件用于测试环境部署
# 2. 请根据实际测试环境修改配置
# 3. 使用测试网络（Sepolia）进行区块链交互
# 4. 不要将包含真实密钥的文件提交到版本控制
#
# 生成日期: 2026-02-26
# ============================================================================

# ============================================================================
# 环境配置
# ============================================================================
ENVIRONMENT=test                          # 测试环境标识
DEBUG=false                               # 禁用调试模式（测试环境建议false）
LOG_LEVEL=info                            # 日志级别: debug, info, warning, error

# ============================================================================
# 服务器配置
# ============================================================================
HOST=0.0.0.0                              # 监听地址
PORT=8000                                 # API服务端口
NEXUS_PORT=8001                           # Nexus协议端口

# 最大并发配置
MAX_AGENTS=50                             # 最大Agent数量（测试环境适中）
MAX_QUEUE_SIZE=500                        # 最大队列大小

# ============================================================================
# 数据库配置
# ============================================================================
# PostgreSQL连接字符串
# 格式: postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql://nautilus_test:en-t8JCHMse56q9sTVlsXzjm3v6ZuuIF@localhost:5432/nautilus_test

# 数据库连接池配置
DB_POOL_SIZE=10                           # 连接池大小
DB_MAX_OVERFLOW=20                        # 最大溢出连接数
DB_POOL_TIMEOUT=30                        # 连接超时（秒）
DB_POOL_RECYCLE=3600                      # 连接回收时间（秒）

# ============================================================================
# Redis配置
# ============================================================================
REDIS_URL=redis://:A1y2lVYj3-3c3__ZZpH5cmOdUv4MQi8-@localhost:6379/1
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=A1y2lVYj3-3c3__ZZpH5cmOdUv4MQi8-
REDIS_DB=1                                # 使用DB 1（区分生产环境）
REDIS_MAX_CONNECTIONS=30

# ============================================================================
# 安全配置 - JWT
# ============================================================================
# JWT密钥 - 用于签名和验证JWT令牌
JWT_SECRET_KEY=VON3mevO2Cy_G5QIjFyPrhl0Wcp3LEyIj9UgpLSfDok
JWT_ALGORITHM=HS256                       # 加密算法
JWT_EXPIRATION_MINUTES=30                 # Token过期时间（分钟）
JWT_REFRESH_EXPIRATION_DAYS=7             # 刷新Token过期时间（天）

# ============================================================================
# 安全配置 - CSRF
# ============================================================================
# CSRF密钥 - 用于防止跨站请求伪造攻击
CSRF_SECRET_KEY=D1bv1T-1MusRBcKbU9LgE5TNgq4GOskP4FTZ5nvsMGE

# ============================================================================
# CORS配置
# ============================================================================
# 允许的前端域名（测试环境）
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://test.nautilus.local
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://test.nautilus.local

# CORS详细配置
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization,X-CSRF-Token

# ============================================================================
# HTTPS配置
# ============================================================================
FORCE_HTTPS=false                         # 测试环境可以使用HTTP
HSTS_MAX_AGE=0                            # 测试环境禁用HSTS
HSTS_INCLUDE_SUBDOMAINS=false
HSTS_PRELOAD=false

# ============================================================================
# 速率限制配置
# ============================================================================
RATE_LIMIT_ENABLED=true                   # 启用速率限制
RATE_LIMIT_STORAGE=redis                  # 存储后端: memory, redis
RATE_LIMIT_LOGIN=10/minute                # 登录接口限制（测试环境宽松）
RATE_LIMIT_API=200/minute                 # 通用API限制
RATE_LIMIT_BLOCKCHAIN=20/minute           # 区块链接口限制
RATE_LIMIT_WEBSOCKET=100/minute           # WebSocket连接限制

# ============================================================================
# 区块链配置 - 测试网络（Sepolia）
# ============================================================================

# --- 网络配置 ---
# 使用Sepolia测试网
BLOCKCHAIN_NETWORK=sepolia                # 测试网络
BLOCKCHAIN_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Infura配置
INFURA_PROJECT_ID=YOUR_INFURA_PROJECT_ID  # [必须修改] 填入你的Infura项目ID
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID

# 备用RPC（Alchemy）
ALCHEMY_API_KEY=YOUR_ALCHEMY_API_KEY      # [可选]
# BLOCKCHAIN_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# --- 智能合约地址 ---
# 部署到Sepolia测试网后填入实际的合约地址
IDENTITY_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
TASK_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
TASK_MARKET_ADDRESS=0x0000000000000000000000000000000000000000
REWARD_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
REWARD_POOL_ADDRESS=0x0000000000000000000000000000000000000000
AGENT_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000

# --- 区块链账户配置 ---
BLOCKCHAIN_ACCOUNT_ADDRESS=0x0000000000000000000000000000000000000000  # [必须修改]

# ============================================================================
# 区块链私钥管理 - 测试环境推荐使用加密文件
# ============================================================================

# 方式1: 环境变量（测试环境可用）
# BLOCKCHAIN_PRIVATE_KEY=your-test-private-key-here

# 方式2: 加密文件存储（推荐）
KEY_SOURCE=encrypted_file
KEY_FILE_PATH=/c/Users/chunx/Projects/nautilus-core/phase3/backend/keys/test_encrypted_key.json
KEY_ENCRYPTION_PASSWORD=CHANGE_THIS_ENCRYPTION_PASSWORD

# --- 密钥轮换策略 ---
KEY_ROTATION_ENABLED=false                # 测试环境可以禁用
KEY_ROTATION_DAYS=90
KEY_ROTATION_WARNING_DAYS=7

# ============================================================================
# Gas费用配置
# ============================================================================
MAX_GAS_PRICE=50000000000                 # 最大Gas价格（50 Gwei，测试网）
GAS_LIMIT=500000                          # Gas限制
GAS_PRICE_MULTIPLIER=1.2                  # Gas价格倍数
GAS_ESTIMATION_BUFFER=1.1                 # Gas估算缓冲

# ============================================================================
# 区块链同步配置
# ============================================================================
BLOCKCHAIN_SYNC_ENABLED=true              # 启用区块链同步
BLOCKCHAIN_SYNC_INTERVAL=30               # 同步间隔（秒）
BLOCKCHAIN_START_BLOCK=                   # 起始区块（留空从最新开始）
BLOCKCHAIN_CONFIRMATION_BLOCKS=3          # 确认区块数（测试网较少）

# ============================================================================
# 监控和日志配置
# ============================================================================

# 日志配置
LOG_FILE=/var/log/nautilus/test_app.log   # 日志文件路径
LOG_MAX_SIZE=50MB                         # 单个日志文件最大大小
LOG_BACKUP_COUNT=5                        # 保留日志文件数量
LOG_FORMAT=json                           # 日志格式: json, text

# Sentry错误追踪（可选）
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# SENTRY_ENVIRONMENT=test
# SENTRY_TRACES_SAMPLE_RATE=0.5

# Prometheus监控
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# 健康检查配置
HEALTH_CHECK_INTERVAL=30                  # 健康检查间隔（秒）
HEALTH_CHECK_TIMEOUT=5                    # 健康检查超时（秒）

# ============================================================================
# 邮件通知配置（可选）
# ============================================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=test-notifications@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply-test@nautilus.local
# SMTP_TLS=true

# 告警邮件接收者
# ALERT_EMAIL_RECIPIENTS=test-admin@nautilus.local

# ============================================================================
# 备份配置
# ============================================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 3 * * *                 # Cron表达式（每天凌晨3点）
BACKUP_RETENTION_DAYS=7                   # 备份保留天数（测试环境较短）
BACKUP_PATH=/var/backups/nautilus/test    # 备份存储路径

# ============================================================================
# 性能优化配置
# ============================================================================
# Worker进程数
WORKERS=2                                 # 测试环境较少

# 每个Worker的线程数
THREADS_PER_WORKER=2

# 请求超时（秒）
REQUEST_TIMEOUT=30

# WebSocket配置
WEBSOCKET_PING_INTERVAL=25
WEBSOCKET_PING_TIMEOUT=60
WEBSOCKET_MAX_MESSAGE_SIZE=10485760       # 10MB

# ============================================================================
# 缓存配置
# ============================================================================
CACHE_ENABLED=true
CACHE_TTL=300                             # 缓存过期时间（秒）
CACHE_MAX_SIZE=500                        # 最大缓存条目数

# ============================================================================
# 任务配置
# ============================================================================
DEFAULT_TASK_TIMEOUT=1800                 # 默认任务超时（秒，测试环境较短）
MAX_TASK_REWARD=1000000000000000000       # 最大任务奖励（1 ETH）
MIN_TASK_REWARD=10000000000000000         # 最小任务奖励（0.01 ETH）
TASK_CLEANUP_INTERVAL=1800                # 任务清理间隔（秒）

# ============================================================================
# 安全增强配置
# ============================================================================
# 密码策略
PASSWORD_MIN_LENGTH=8                     # 测试环境可以宽松
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGITS=true
PASSWORD_REQUIRE_SPECIAL=false            # 测试环境可以不要求

# 会话配置
SESSION_TIMEOUT=3600                      # 会话超时（秒）
SESSION_ABSOLUTE_TIMEOUT=86400            # 绝对超时（秒）

# 防暴力破解
MAX_LOGIN_ATTEMPTS=10                     # 测试环境宽松
LOGIN_LOCKOUT_DURATION=300                # 锁定时长（秒）

# ============================================================================
# 第三方服务配置（可选）
# ============================================================================

# LLM提供商配置
CLAUDE_API_KEY=YOUR_CLAUDE_API_KEY        # [可选]
CLAUDE_BASE_URL=https://api.anthropic.com
CLAUDE_MODEL=claude-sonnet-4.6

MINIMAX_API_KEY=YOUR_MINIMAX_API_KEY      # [可选]
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.5

# ============================================================================
# 开发和调试配置
# ============================================================================
ENABLE_API_DOCS=true                      # 测试环境可以启用API文档
ENABLE_SWAGGER=true                       # 启用Swagger UI
ENABLE_REDOC=true                         # 启用ReDoc
ENABLE_PROFILING=false                    # 性能分析

# ============================================================================
# 合规和审计配置
# ============================================================================
AUDIT_LOG_ENABLED=true                    # 启用审计日志
AUDIT_LOG_PATH=/var/log/nautilus/test_audit.log
GDPR_COMPLIANCE=true                      # GDPR合规
DATA_RETENTION_DAYS=90                    # 数据保留天数（测试环境较短）

# ============================================================================
# 测试环境特定配置
# ============================================================================
# 测试数据生成
ENABLE_TEST_DATA=true                     # 启用测试数据生成
TEST_DATA_SEED=42                         # 测试数据种子

# 测试模式
TEST_MODE=true                            # 测试模式标识
SKIP_BLOCKCHAIN_VERIFICATION=false        # 是否跳过区块链验证

# ============================================================================
# 配置验证检查清单
# ============================================================================
#
# 部署前请确认：
# [ ] 数据库连接信息正确
# [ ] Redis连接信息正确
# [ ] CORS域名配置正确
# [ ] 区块链RPC URL可访问（Sepolia测试网）
# [ ] Infura/Alchemy项目ID已配置
# [ ] 智能合约已部署到Sepolia并填入地址
# [ ] 私钥管理方式已选择并配置
# [ ] 日志目录有写入权限
# [ ] 备份目录有写入权限
# [ ] 测试环境网络连通性
#
# ============================================================================
