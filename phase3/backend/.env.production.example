# 生产环境配置示例
# ⚠️ 这是示例文件，实际部署时需要修改所有密钥和敏感信息

# 环境标识
ENVIRONMENT=production

# 应用配置
APP_NAME=Nautilus
APP_VERSION=3.0.0
DEBUG=false
LOG_LEVEL=INFO

# 服务器配置
HOST=0.0.0.0
PORT=8000
WORKERS=4

# 数据库配置（生产）
# ⚠️ 修改密码
DATABASE_URL=postgresql://nautilus_prod:LIoX9Brg5xoANOokND4t3uy7PSRhVZAq@postgres:5432/nautilus_production
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# Redis配置（生产）
# ⚠️ 修改密码
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=UHvgyqnG61-5CCKmPWLVGg
REDIS_DB=0
REDIS_MAX_CONNECTIONS=50

# 安全配置
# ⚠️ 修改所有密钥
SECRET_KEY=HlJ1eoeBvydOXQPaVKvSGQ4eegVZWLsuStTa-96ZsNs
JWT_SECRET_KEY=7wrIME45MNtd8RxH51--tOVNhWf6F1zTzmNR6bp4iKY
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS配置（生产域名）
# ⚠️ 修改为实际域名
CORS_ORIGINS=["https://nautilus.example.com","https://www.nautilus.example.com"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["GET","POST","PUT","DELETE","PATCH"]
CORS_ALLOW_HEADERS=["*"]

# 速率限制（生产）
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=1000 per minute
RATE_LIMIT_HEALTH=100 per minute
RATE_LIMIT_API=500 per minute

# 区块链配置（生产）
# ⚠️ 修改为实际配置
BLOCKCHAIN_NETWORK=mainnet
SEPOLIA_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY_HERE
CONTRACT_ADDRESS=0xYOUR_PRODUCTION_CONTRACT_ADDRESS_HERE
PRIVATE_KEY=YOUR_SECURE_PRIVATE_KEY_HERE

# 监控配置
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
METRICS_ENABLED=true

# 日志配置
LOG_FORMAT=json
LOG_FILE=/var/log/nautilus/app.log
LOG_ROTATION=daily
LOG_RETENTION_DAYS=30

# 缓存配置
CACHE_ENABLED=true
CACHE_TTL=300
CACHE_MAX_SIZE=1000

# SSL/TLS配置
# ⚠️ 修改为实际证书路径
SSL_ENABLED=true
SSL_CERT_PATH=/etc/ssl/certs/nautilus.crt
SSL_KEY_PATH=/etc/ssl/private/nautilus.key

# 健康检查配置
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10
HEALTH_CHECK_RETRIES=3

# 特性开关
FEATURE_OAUTH=true
FEATURE_BLOCKCHAIN=true
FEATURE_WEBSOCKET=true
FEATURE_CACHE=true
FEATURE_RATE_LIMIT=true

# 第三方服务
# ⚠️ 修改为实际配置
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# 备份配置
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# 告警配置
# ⚠️ 修改为实际配置
ALERT_EMAIL=ops@nautilus.example.com
ALERT_SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# 性能优化
GZIP_ENABLED=true
GZIP_MIN_SIZE=1000
STATIC_CACHE_MAX_AGE=86400

# 会话配置
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=lax
SESSION_MAX_AGE=3600

# 时区配置
TIMEZONE=UTC

# 维护模式
MAINTENANCE_MODE=false
