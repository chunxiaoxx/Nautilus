# 生产环境配置模板
# 复制此文件为 .env.production 并填写实际值

# 环境标识
ENVIRONMENT=production

# 应用配置
APP_NAME=Nautilus
APP_VERSION=3.0.0
DEBUG=false
LOG_LEVEL=INFO

# 服务器配置
HOST=0.0.0.0
PORT=8000
WORKERS=4

# 数据库配置（生产）
DATABASE_URL=postgresql://nautilus_prod:CHANGE_ME_STRONG_PASSWORD@postgres:5432/nautilus_production
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# Redis配置（生产）
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# 安全配置
SECRET_KEY=CHANGE_ME_GENERATE_STRONG_SECRET_KEY_HERE
JWT_SECRET_KEY=CHANGE_ME_GENERATE_JWT_SECRET_KEY_HERE

# CORS配置（生产域名）
CORS_ORIGINS=["https://nautilus.example.com"]

# 速率限制（生产）
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=1000 per minute

# 区块链配置（生产）
BLOCKCHAIN_NETWORK=mainnet
SEPOLIA_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# SSL/TLS配置
SSL_ENABLED=true
SSL_CERT_PATH=/etc/ssl/certs/nautilus.crt
SSL_KEY_PATH=/etc/ssl/private/nautilus.key

# 监控配置
PROMETHEUS_ENABLED=true
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# 备份配置
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
