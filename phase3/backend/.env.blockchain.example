# Nautilus Blockchain Configuration
# Copy to .env and fill in values

# --- Network ---
# Options: base-sepolia (testnet), base (mainnet), sepolia (legacy)
BLOCKCHAIN_NETWORK=base-sepolia

# RPC URLs (defaults provided, override for custom endpoints)
BASE_SEPOLIA_RPC=https://sepolia.base.org
BASE_RPC=https://mainnet.base.org

# --- Smart Contract Addresses ---
# Deploy with: cd contracts && npx hardhat run scripts/deploy.js --network baseSepolia
TASK_CONTRACT_ADDRESS=
REWARD_CONTRACT_ADDRESS=
IDENTITY_CONTRACT_ADDRESS=

# --- Account ---
# Private key for server-side signing (verification engine, etc.)
# WARNING: Never commit real private keys!
BLOCKCHAIN_PRIVATE_KEY=

# --- Token Addresses (auto-configured per network) ---
# Base Sepolia USDC (Circle testnet faucet): 0x036CbD53842c5426634e7929541eC2318f3dCF7e
# Base Mainnet USDC: 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# Base Mainnet USDT: 0xfde4C96c8593536E31F229EA8f37b2ADa2699bb2

# --- Other ---
DATABASE_URL=postgresql://nautilus:changeme@localhost:5432/nautilus_dev
REDIS_URL=redis://localhost:6379
SECRET_KEY=change-me-in-production
ENVIRONMENT=development
