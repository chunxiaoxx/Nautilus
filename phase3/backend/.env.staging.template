# ============================================================================
# Nautilus Phase 3 Backend - Staging环境配置
# ============================================================================

# ----------------------------------------------------------------------------
# 应用配置
# ----------------------------------------------------------------------------
ENVIRONMENT=staging
DEBUG=False
LOG_LEVEL=INFO
APP_NAME=Nautilus
APP_VERSION=3.0.0

# ----------------------------------------------------------------------------
# 数据库配置
# ----------------------------------------------------------------------------
DATABASE_URL=postgresql://nautilus:nautilus_staging_2024@postgres:5432/nautilus_staging
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600

# ----------------------------------------------------------------------------
# Redis配置
# ----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5

# ----------------------------------------------------------------------------
# 区块链配置
# ----------------------------------------------------------------------------
# 请替换为您的Infura密钥
BLOCKCHAIN_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY_HERE
BLOCKCHAIN_NETWORK=sepolia
BLOCKCHAIN_CHAIN_ID=11155111
BLOCKCHAIN_GAS_LIMIT=3000000
BLOCKCHAIN_GAS_PRICE_MULTIPLIER=1.2

# 智能合约地址（Sepolia测试网）
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# ----------------------------------------------------------------------------
# 安全配置
# ----------------------------------------------------------------------------
# 生产环境请使用强密钥
SECRET_KEY=staging-secret-key-change-in-production
JWT_SECRET=staging-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# CORS配置
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=true

# ----------------------------------------------------------------------------
# API配置
# ----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8001
API_PREFIX=/api
API_DOCS_URL=/docs
API_REDOC_URL=/redoc

# 速率限制
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=100

# ----------------------------------------------------------------------------
# 监控配置
# ----------------------------------------------------------------------------
PROMETHEUS_PORT=9090
PROMETHEUS_ENABLED=true
GRAFANA_PORT=3000

# 日志配置
LOG_FORMAT=json
LOG_FILE=/app/logs/nautilus.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10

# ----------------------------------------------------------------------------
# 缓存配置
# ----------------------------------------------------------------------------
CACHE_ENABLED=true
CACHE_DEFAULT_TIMEOUT=300
CACHE_KEY_PREFIX=nautilus:staging:

# 特定缓存超时（秒）
CACHE_TASKS_TIMEOUT=60
CACHE_AGENTS_TIMEOUT=60
CACHE_EPIPLEXITY_TIMEOUT=3600

# ----------------------------------------------------------------------------
# Epiplexity配置
# ----------------------------------------------------------------------------
EPIPLEXITY_MIN_THRESHOLD=0.1
EPIPLEXITY_MAX_THRESHOLD=10.0
EPIPLEXITY_CALCULATION_TIMEOUT=10

# ----------------------------------------------------------------------------
# Agent生存机制配置
# ----------------------------------------------------------------------------
SURVIVAL_CHECK_INTERVAL=3600
SURVIVAL_MIN_SCORE=0.0
SURVIVAL_MAX_SCORE=100.0
SURVIVAL_PENALTY_RATE=0.1

# ----------------------------------------------------------------------------
# 任务配置
# ----------------------------------------------------------------------------
TASK_DEFAULT_TIMEOUT=3600
TASK_MAX_TIMEOUT=86400
TASK_AUTO_ASSIGNMENT_ENABLED=true
TASK_AUTO_ASSIGNMENT_INTERVAL=30

# ----------------------------------------------------------------------------
# WebSocket配置
# ----------------------------------------------------------------------------
WEBSOCKET_ENABLED=true
WEBSOCKET_PATH=/nexus
WEBSOCKET_PING_INTERVAL=25
WEBSOCKET_PING_TIMEOUT=60

# ----------------------------------------------------------------------------
# 性能配置
# ----------------------------------------------------------------------------
WORKER_PROCESSES=4
WORKER_CONNECTIONS=1000
KEEPALIVE_TIMEOUT=65

# ----------------------------------------------------------------------------
# 测试配置
# ----------------------------------------------------------------------------
TESTING=false
TEST_DATABASE_URL=sqlite:///./test.db

# ----------------------------------------------------------------------------
# 外部服务配置
# ----------------------------------------------------------------------------
# OpenAI API（如果需要）
OPENAI_API_KEY=

# Infura API（区块链）
INFURA_PROJECT_ID=YOUR_INFURA_PROJECT_ID
INFURA_PROJECT_SECRET=

# ----------------------------------------------------------------------------
# OAuth配置（如果需要）
# ----------------------------------------------------------------------------
OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ----------------------------------------------------------------------------
# 邮件配置（如果需要）
# ----------------------------------------------------------------------------
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@nautilus.ai

# ----------------------------------------------------------------------------
# 备份配置
# ----------------------------------------------------------------------------
BACKUP_ENABLED=true
BACKUP_INTERVAL=86400
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/app/backups

# ----------------------------------------------------------------------------
# 特性开关
# ----------------------------------------------------------------------------
FEATURE_KNOWLEDGE_EMERGENCE=true
FEATURE_CAPABILITY_CAPSULE=true
FEATURE_AGENT_SPECIALIZATION=true
FEATURE_TASK_RECOMMENDATION=true
FEATURE_LEARNING_TRACKING=true

# ----------------------------------------------------------------------------
# 调试配置
# ----------------------------------------------------------------------------
DEBUG_SQL=false
DEBUG_CACHE=false
DEBUG_WEBSOCKET=false
