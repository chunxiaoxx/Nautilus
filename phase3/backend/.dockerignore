# ============================================
# .dockerignore - Docker构建排除文件
# ============================================
# 优化Docker构建上下文，减少镜像大小和构建时间
# ============================================

# ============================================
# Python相关
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.pyc
*.pyo
*.pyd
pip-log.txt
pip-delete-this-directory.txt

# ============================================
# 虚拟环境
# ============================================
venv/
env/
ENV/
.venv
env.bak/
venv.bak/

# ============================================
# 测试和覆盖率
# ============================================
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/
nosetests.xml
test-results/
tests/
test_*.py
*_test.py

# ============================================
# IDE和编辑器
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/
*.sublime-project
*.sublime-workspace

# ============================================
# Git
# ============================================
.git/
.gitignore
.gitattributes
.gitmodules

# ============================================
# Docker相关
# ============================================
Dockerfile*
docker-compose*.yml
.dockerignore
*.dockerfile

# ============================================
# 环境变量（保留example）
# ============================================
.env
.env.local
.env.*.local
!.env.example
!.env.*.example

# ============================================
# 数据库文件
# ============================================
*.db
*.sqlite
*.sqlite3
*.db-journal

# ============================================
# 日志文件
# ============================================
*.log
logs/
*.log.*

# ============================================
# 临时文件
# ============================================
*.tmp
*.temp
*.bak
*.swp
.DS_Store
Thumbs.db
desktop.ini

# ============================================
# 文档（生产环境不需要）
# ============================================
*.md
!README.md
docs/
documentation/

# ============================================
# CI/CD
# ============================================
.github/
.gitlab-ci.yml
.travis.yml
.circleci/
azure-pipelines.yml
Jenkinsfile

# ============================================
# 开发工具配置
# ============================================
.editorconfig
.eslintrc*
.prettierrc*
.pylintrc
mypy.ini
.mypy_cache/
.ruff_cache/
.bandit
.coveragerc

# ============================================
# 构建产物和缓存
# ============================================
dist/
build/
*.egg-info/
.eggs/
*.whl

# ============================================
# 监控和性能分析
# ============================================
# monitoring/ - REMOVED: needed in production for metrics
*.prof
*.pstats

# ============================================
# 脚本和工具（开发用）
# ============================================
scripts/
tools/
demo_*.py
benchmark_*.py
analyze_*.py
run_*.sh
run_*.bat

# ============================================
# 报告文件
# ============================================
*_REPORT.md
*_SUMMARY.md
*_COMPLETE.md
*_DONE.md
*_FINISHED.md
COMPLETE*.md
FINAL*.md
PROJECT*.md
WORK*.md
DELIVERY*.md
STRESS_TEST*.md
README_STRESS*.md
PERFORMANCE*.md
OPTIMIZATION*.md

# ============================================
# 备份文件
# ============================================
*.backup
*.old
*~
