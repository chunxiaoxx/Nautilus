# Database Configuration
# 选项1: PostgreSQL（生产环境推荐）
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nautilus

# 选项2: SQLite（开发/测试推荐，无需额外配置）
DATABASE_URL=sqlite:///./nautilus.db

# 选项3: SQLite内存数据库（仅用于测试）
# DATABASE_URL=sqlite:///:memory:

DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# Redis Configuration
# Redis可选，如果没有安装可以注释掉
# REDIS_URL=redis://localhost:6379/0

# JWT Configuration
JWT_SECRET=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION=86400

# CSRF Configuration
CSRF_SECRET_KEY=your-csrf-secret-here-change-in-production

# Application Settings
APP_NAME=Nautilus
APP_VERSION=3.0.0
DEBUG=true
LOG_LEVEL=INFO

# Web3Auth Configuration
WEB3AUTH_CLIENT_ID=BFUjm9FfKxfQwzGYgWlCnsrCK_7KZPezFDGg7CeM3V_nOP20FZK0WPz7yB8bMtez_JnznLnheSiOXBw3V6zY-7A
WEB3AUTH_JWKS_URL=https://api-auth.web3auth.io/.well-known/jwks.json
WEB3AUTH_ENVIRONMENT=sapphire_devnet

# Wallet Encryption
WALLET_MASTER_KEY=  # Base64-encoded 32-byte key. Generate with: python3 -c "import secrets,base64;print(base64.b64encode(secrets.token_bytes(32)).decode())"
