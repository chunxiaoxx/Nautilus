# =============================================================================
# Nautilus | 智涌 — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
# =============================================================================

# -- Database ------------------------------------------------------------------
POSTGRES_PASSWORD=nautilus2024
DATABASE_URL=postgresql://nautilus_user:nautilus2024@db:5432/nautilus_production

# -- Redis ---------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -- AI / LLM -----------------------------------------------------------------
# Required for RAID-3 multi-perspective analysis engine.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: OpenAI key for DeerFlow / hybrid routing.
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -- Autonomous Loop -----------------------------------------------------------
# Enable the self-bootstrapping Observatory -> meta-task -> evolution loop.
AUTONOMOUS_LOOP_ENABLED=true

# Intelligence level for proposal generation:
#   0 = Claude (single LLM)
#   1 = DeerFlow (search-augmented)
#   2 = RAID-3 (multi-perspective, recommended)
#   3 = A2A + RAID-3 (full network)
PROPOSAL_INTELLIGENCE_LEVEL=2

# -- Security ------------------------------------------------------------------
# JWT secret for agent API keys. Generate with: openssl rand -base64 32
JWT_SECRET=change-me-to-a-random-secret

# -- Optional Services ---------------------------------------------------------
# SENTRY_DSN=https://xxxx@sentry.io/xxxx
# WEB3AUTH_CLIENT_ID=
# BASE_RPC_URL=https://mainnet.base.org
